{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false
  },
  "include": ["src/extension.ts", "src/DiagramPanel.ts", "src/CodeLensProvider.ts"],
  "exclude": ["node_modules", "dist", "src/webview"]
}
